TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Telegram chat ID (usually a group you create for your team, with the bot added to it)
# that receives internal notifications: new leads, deals won/lost, new projects, invoices.
# Find it by adding the bot to the group, sending any message in it, then checking
# https://api.telegram.org/bot<TOKEN>/getUpdates in a browser.
NOTIFY_CHAT_ID=

# Port the local messaging backend (server/index.js) listens on — dev only.
PORT=4000

# Base URL the frontend uses to reach the messaging backend.
# Dev: the local Express server above. Production: the deployed Cloudflare Worker
# (worker/index.js), which holds TELEGRAM_BOT_TOKEN/NOTIFY_CHAT_ID as real Worker
# secrets — set via `wrangler secret put <NAME>`, never committed here.
VITE_API_BASE_URL=http://localhost:4000
