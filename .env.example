TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Telegram chat ID (usually a group you create for your team, with the bot added to it)
# that receives internal notifications: new leads, deals won/lost, new projects, invoices.
# Find it by adding the bot to the group, sending any message in it, then hitting
# GET /api/telegram/updates on the running server.
NOTIFY_CHAT_ID=

# Port the messaging backend (server/index.js) listens on
PORT=4000

# Base URL the frontend uses to reach the local messaging backend (dev only).
VITE_API_BASE_URL=http://localhost:4000

# --- Production (GitHub Pages) ---
# GitHub Pages can't run server/index.js, so the deployed build instead dispatches
# .github/workflows/notify.yml, which sends the Telegram message using the
# TELEGRAM_BOT_TOKEN/NOTIFY_CHAT_ID *repository secrets* (not this file).
#
# VITE_GITHUB_DISPATCH_TOKEN is injected at build time in .github/workflows/deploy.yml
# from the WORKFLOW_DISPATCH_TOKEN repo secret — a fine-grained GitHub PAT scoped to
# "Actions: read and write" on this repo only. It ends up in the public JS bundle,
# so keep its scope as narrow as possible and rotate it if you suspect it's been misused.
# Leave blank for local dev — the app falls back to VITE_API_BASE_URL above.
VITE_GITHUB_DISPATCH_TOKEN=
